modules = ["nodejs-20"]
run = "npm run dev"

[agent]
expertMode = true

[[ports]]
localPort = 3001
externalPort = 3001

[[ports]]
localPort = 5173
externalPort = 80

[[ports]]
localPort = 5174
externalPort = 3000

[workflows]
runButton = "Dev"

[[workflows.workflow]]
name = "Dev"
mode = "sequential"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "npm run dev"

[deployment]
deploymentTarget = "cloudrun"
